# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Backend
BACKEND_PORT=3001
LOG_LEVEL=info
# Use localhost when running backend directly on host.
# Docker Compose backend uses DATABASE_URL with host `db` from compose defaults.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/todo_app

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=todo_app
POSTGRES_USER=postgres
# Local development-only default. Override for any shared environment.
POSTGRES_PASSWORD=postgres
