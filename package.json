{
  "name": "todo-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "test:integration": "npm run test:integration -w apps/backend",
    "prisma:generate": "npm run prisma:generate -w apps/backend",
    "prisma:migrate:dev": "npm run prisma:migrate:dev -w apps/backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy -w apps/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2"
  }
}
